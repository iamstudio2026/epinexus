# Endpoint del proxy RAG (NO pongas la API key en el front).
# Local con server/rag.js:
VITE_RAG_ENDPOINT=http://localhost:8787/rag
# Producción (ejemplo con tu n8n):
# VITE_RAG_ENDPOINT=https://n8n.iamstudio.cloud/webhook/epinexus-rag

# --- Solo para server/rag.js (lado servidor, nunca expuesto al navegador) ---
# ANTHROPIC_API_KEY=sk-ant-...
# PORT=8787
# CORS_ORIGIN=http://localhost:5173
